# ========================================
# EMAIL CONFIGURATION (Gmail)
# ========================================
# INSTRUCTIONS: Get Gmail App Password
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Sign in to your Google Account
# 3. Select "Mail" as the app
# 4. Select "Other" as device and name it "e-CARD"
# 5. Click GENERATE
# 6. Copy the 16-character password (spaces included)
# 7. Paste it below as EMAIL_PASS
# NOTE: Your regular Gmail password will NOT work! Use App Password only.
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ========================================
# FIREBASE CONFIGURATION (Vite/Frontend)
# ========================================
# INSTRUCTIONS: Get Firebase Config from Firebase Console
# 1. Go to: https://console.firebase.google.com
# 2. Select your project
# 3. Click the gear icon (Project Settings)
# 4. Scroll to "Your apps" section
# 5. Click on your web app (or create one with </> icon)
# 6. Copy the configuration object
# 7. Paste values below (VITE_ prefix is required for Vite)
# NOTE: These are safe to expose in frontend (public keys)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id



# ========================================
# CLOUDINARY CONFIGURATION
# ========================================
# INSTRUCTIONS: Get Cloudinary Credentials
# 1. Go to: https://cloudinary.com/console
# 2. Sign in to your account
# 3. Dashboard shows your Cloud Name, API Key, API Secret
# 4. For Upload Preset:
#    - Go to Settings → Upload
#    - Scroll to "Upload presets"
#    - Click "Add upload preset"
#    - Name it (e.g., "e-card-uploads")
#    - Set Signing Mode to "Unsigned"
#    - Save
# 5. Paste values below
# WARNING: Keep API_SECRET private! Never expose in frontend.
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_API_KEY=your_api_key
VITE_CLOUDINARY_API_SECRET=your_api_secret
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ========================================
# INSTRUCTIONS FOR USE:
# ========================================
# 1. Copy this file and rename to .env (remove .example)
# 2. Fill in all YOUR_ values with actual credentials
# 3. For backend (Node.js) variables, remove 'VITE_' prefix
# 4. NEVER commit .env file to GitHub! Add to .gitignore
# 5. For cPanel, set these as Environment Variables in Node.js app